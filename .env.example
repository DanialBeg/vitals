# Copy to .env and fill in from your Supabase project (Project Settings → API).
# Both values are safe to expose in the client bundle: the anon key is public by
# design, and access is enforced by Row Level Security, not secrecy.
# Leave these blank and the app still works fully offline/locally — sync is additive.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
